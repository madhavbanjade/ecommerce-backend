generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  user
  admin
}

enum Size {
  sm
  md
  lg
  xl
  xxl
  xxxl
  xl4
}

enum Gender {
  Male
  Female
  Unisex
}


//users schema
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  username  String?  @unique
  password  String?
  role      Role     @default(user)
  createdAt DateTime @default(now())
}


//product schema 
model Product {
  id              Int           @id @default(autoincrement())
  images          String[]
  name            String        @unique
  slug            String        @unique
  description     String
  gender          Gender
  category        Category[]
  originalPrice   Int
  discountPercent Float?
  dicountPrice    Float?
  tag             String
  sizes           ProductSize[] @relation("ProductToProductSize")
  isAvilable      Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model ProductSize {
  productId      Int
  size           Size
  stockQuantity Int
  product        Product @relation("ProductToProductSize", fields: [productId], references: [id], onDelete: Cascade)
  @@unique([productId, size])
}

model Category {
  id  String  @id @default(uuid())
  name String 
  products  Product[]
}


